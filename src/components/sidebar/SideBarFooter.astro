---
import { Icon } from 'astro-icon/components';
---

<div class="pointer-events-none sticky bottom-12 block h-10 justify-center">
</div>
<div
	class="social-icons bg-blur sticky bottom-0 my-5 flex w-full items-center justify-center bg-gradient-to-b from-transparent to-base-300 pb-3 pt-8 dark:to-black/20"
>
	<a
		href="https://artemist.com.au/"
		target="_blank"
		class="mx-3"
		aria-label="Support my work"
		title="Support my work"
	>
		<Icon class="h-6 w-6" name="coffee" />
	</a>
	<a
		href="https://github.com/paulhaze/"
		target="_blank"
		class="mx-3"
		aria-label="Github repo"
		title="Github Repo"
	>
		<Icon class="h-6 w-6" name="github" />
	</a>
	<a
		href="https://twitter.com/paulhaze/"
		target="_blank"
		class="mx-3"
		aria-label="Twitter"
		title="Twitter"
	>
		<Icon class="h-6 w-6" name="twitter" />
	</a>
	<a
		href="https://linkedin.com/paulhaze/"
		target="_blank"
		class="mx-3"
		aria-label="Twitter"
		title="Twitter"
	>
		<Icon class="h-6 w-6" name="linkedin" />
	</a>
</div>
